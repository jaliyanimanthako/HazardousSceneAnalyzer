# Copy this file to .env and fill in your keys — do NOT commit .env

# HuggingFace token — required to download gated models (e.g. Llama-3.2-3B-Instruct)
# Get your token at https://huggingface.co/settings/tokens
# Accept the model licence at https://huggingface.co/meta-llama/Llama-3.2-3B-Instruct
HF_TOKEN=

# ── Online mode (online.py) ───────────────────────────────────────────────────

# OpenRouter (default provider) — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DashScope / Alibaba Qwen direct — get key at https://dashscope.console.aliyun.com
QWEN_API_KEY=

# OpenAI — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
