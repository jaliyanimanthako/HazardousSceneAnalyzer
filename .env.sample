# API keys for online.py
# Copy this file to .env and fill in your keys — do NOT commit .env

# OpenRouter (default provider) — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DashScope / Alibaba Qwen direct — get key at https://dashscope.console.aliyun.com
QWEN_API_KEY=

# OpenAI — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
